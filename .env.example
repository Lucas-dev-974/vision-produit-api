NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=monappli
DB_SYNC=false
# Si false : en development, les migrations s'appliquent au démarrage du serveur (voir index.ts).
# Sinon : npm run migration:run
# RUN_MIGRATIONS_ON_START=false

CORS_ORIGIN=http://localhost:5173

JWT_ACCESS_SECRET=change-me-to-at-least-64-characters-hex-or-random-string-for-access-token-signing!!
JWT_REFRESH_SECRET=change-me-to-at-least-64-characters-hex-or-random-string-for-refresh-token-signing!!
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

INSEE_API_KEY=
BREVO_API_KEY=
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
