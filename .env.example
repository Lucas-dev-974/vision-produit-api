NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=monappli
DB_SYNC=false
# Si false : en development, les migrations s'appliquent au démarrage du serveur (voir index.ts).
# Sinon : npm run migration:run
# RUN_MIGRATIONS_ON_START=false

CORS_ORIGIN=http://localhost:5173
# URL publique du front (utilisée dans les e-mails). Par défaut = CORS_ORIGIN.
PUBLIC_APP_URL=http://localhost:5173

# Phase de pré-lancement : `false` = seuls les comptes admin peuvent se connecter
# et l'inscription publique est fermée (les pré-inscriptions restent ouvertes).
APP_ACCESS_OPEN=false

JWT_ACCESS_SECRET=change-me-to-at-least-64-characters-hex-or-random-string-for-access-token-signing!!
JWT_REFRESH_SECRET=change-me-to-at-least-64-characters-hex-or-random-string-for-refresh-token-signing!!
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

INSEE_API_KEY=
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@example.com
BREVO_SENDER_NAME=MonAppli
ADMIN_NOTIFICATION_EMAIL=
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
